            "compilerPath": "C:/mingw64_15/mingw64/bin/gcc.exe", // MinGW的gcc路径
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64" // 改为gcc模式，适配MinGW
        }
    ],
    "version": 4
}
